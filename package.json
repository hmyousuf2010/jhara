{
	"name": "jhara",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"hono": "^4.11.7",
			"@trpc/server": "^11.13.4",
			"better-auth": "1.5.5",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"react": "^19.2.3",
			"react-dom": "^19.2.3",
			"sonner": "^2.0.5",
			"@prisma/client": "^7.2.0",
			"@trpc/client": "^11.13.4",
			"@polar-sh/better-auth": "^1.8.3",
			"@types/react": "^19.2.10",
			"@types/react-dom": "^19.2.3",
			"tailwindcss": "^4.1.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @jhara/db db:push",
		"db:studio": "turbo -F @jhara/db db:studio",
		"db:generate": "turbo -F @jhara/db db:generate",
		"db:migrate": "turbo -F @jhara/db db:migrate",
		"db:start": "turbo -F @jhara/db db:start",
		"db:watch": "turbo -F @jhara/db db:watch",
		"db:stop": "turbo -F @jhara/db db:stop",
		"db:down": "turbo -F @jhara/db db:down",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@jhara/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@jhara/config": "workspace:*",
		"@types/bun": "catalog:",
		"husky": "^9.1.7",
		"lint-staged": "^16.1.2",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		],
		"*.rs": [
			"cargo fmt --"
		]
	},
	"packageManager": "bun@1.3.11"
}
